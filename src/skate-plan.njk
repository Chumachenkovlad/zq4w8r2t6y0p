          <rect x="2" y="-18" width="20" height="14" rx="4" fill="#FF4A1C" stroke="#17150F" stroke-width="1.5"/>
          <rect x="42" y="-18" width="18" height="14" rx="4" fill="#17150F"/>
          <text x="0" y="36" fill="#6B6657" font-family="JetBrains Mono" font-size="9">1·ПРИСІД</text>
        </g>
        <!-- frame 2: pop (tail on right going down) -->
        <g transform="translate(95,90) rotate(-20 36 14)">
          <path d="M0,12 h64 q8,0 8,-8 v-2 q0,-8 -8,-8 h-64 q-8,0 -8,8 v2 q0,8 8,8z" fill="#DCD7CB" stroke="#17150F" stroke-width="2"/>
          <rect x="2" y="-18" width="20" height="14" rx="4" fill="#FF4A1C" stroke="#17150F" stroke-width="1.5"/>
          <rect x="44" y="-18" width="18" height="14" rx="4" fill="#17150F"/>
        </g>
        <text x="95" y="131" fill="#6B6657" font-family="JetBrains Mono" font-size="9">2·ПОП ТЕЙЛОМ</text>
        <!-- frame 3: slide (front/right foot slides leftward toward nose) -->
        <g transform="translate(185,72) rotate(8 36 14)">
          <path d="M0,12 h64 q8,0 8,-8 v-2 q0,-8 -8,-8 h-64 q-8,0 -8,8 v2 q0,8 8,8z" fill="#DCD7CB" stroke="#17150F" stroke-width="2"/>
          <rect x="22" y="-18" width="22" height="14" rx="4" fill="#FF4A1C" stroke="#17150F" stroke-width="1.5"/>
          <path d="M20,-11 l-20,-6" stroke="#FF4A1C" stroke-width="2.5" marker-end="url(#arE)"/>
          <rect x="50" y="-18" width="16" height="14" rx="4" fill="#17150F"/>
        </g>
        <text x="178" y="131" fill="#6B6657" font-family="JetBrains Mono" font-size="9">3·ТЯГНЕШ ПРАВУ ←</text>
        <!-- frame 4: level -->
        <g transform="translate(272,64)">
          <path d="M0,12 h64 q8,0 8,-8 v-2 q0,-8 -8,-8 h-64 q-8,0 -8,8 v2 q0,8 8,8z" fill="#DCD7CB" stroke="#17150F" stroke-width="2"/>
          <rect x="6" y="-18" width="20" height="14" rx="4" fill="#FF4A1C" stroke="#17150F" stroke-width="1.5"/>
          <rect x="42" y="-18" width="18" height="14" rx="4" fill="#17150F"/>
          <path d="M32,22 l0,12" stroke="#FF4A1C" stroke-width="2.5" marker-end="url(#arE)"/>
        </g>
        <text x="272" y="131" fill="#6B6657" font-family="JetBrains Mono" font-size="9">4·ВИРІВНЯВ</text>
      </svg>
    how:
      - "<b>Стійка:</b> <b>ліва (задня)</b> носком на краю тейлу, <b>права (передня)</b> — посередині дошки."
      - "<b>Присід:</b> зігни коліна, опусти центр ваги."
      - "<b>Поп:</b> різко вистрель тейлом униз <b>лівою</b> й одночасно вистрибни вгору."
      - "<b>Слайд:</b> у стрибку тягни <b>праву</b> ногу боковою стороною кросівка вгору до носа дошки (уперед — тобто вліво по дошці)."
      - "<b>Рівняння:</b> у верхній точці вирівняй дошку обома ногами горизонтально."
      - "<b>Приземлення:</b> сідай на дошку <b>обома ногами над болтами</b>, гаси удар зігнутими колінами."
    mistakes:
      - "Не тягнеш передню ногу — дошка не злітає рівно. Веди кросівком по гриптейпу вгору."
      - "Поп і стрибок нарізно. Це має бути один вибуховий рух."
      - "Приземлення серединою дошки замість болтів — ризик зламати дошку й себе."
      - "Вчиш олі на ходу. Спочатку — стоячи на місці (на траві чи об бордюр)."
    tip: "розбий олі на «поп окремо» і «слайд окремо», а потім склей. Це найдовший крок у плані — заклади на нього кілька тижнів і не злися на себе."
    video: "https://www.youtube.com/results?search_query=how+to+ollie+for+beginners+step+by+step"
    reps: "2–4 тижні"
  - id: 9
    label: "Перше обертання"
    title: "Поп-шувіт (Pop Shuvit)"
    goal: "крутнути дошку на 180° під ногами й приземлитись назад на неї."
    svg: |
      <svg class="diagram" viewBox="0 0 320 150" role="img" aria-label="Обертання дошки на 180 градусів — goofy">
        <rect width="320" height="150" fill="#fff"/>
        <g transform="translate(110,40)">
          <path d="M0,30 q0,-28 28,-28 h44 q28,0 28,28 q0,28 -28,28 h-44 q-28,0 -28,-28 z" fill="#DCD7CB" stroke="#17150F" stroke-width="3"/>
          <circle cx="50" cy="8" r="5" fill="#FF4A1C"/>
          <text x="40" y="-6" fill="#FF4A1C" font-family="JetBrains Mono" font-size="9">NOSE ←</text>
        </g>
        <path d="M250,90 a90,40 0 1 1 -180,0" fill="none" stroke="#FF4A1C" stroke-width="3" stroke-dasharray="6 5" marker-end="url(#arE)"/>
        <text x="115" y="135" fill="#17150F" font-family="JetBrains Mono" font-size="11" font-weight="700">ДОШКА КРУТИТЬСЯ 180°</text>
      </svg>
    how:
      - "Стійка майже як в олі, але задня нога готова «зачерпнути» тейл назад."
      - "Роби поп і одночасно <b>скребком задньої ноги</b> крутни дошку назад на пів-оберта."
      - "Підтягни ноги, дай дошці провернутись на 180° під тобою."
      - "Лови дошку ногами над болтами й приземляйся з зігнутими колінами."
    mistakes:
      - "Дошка крутиться, але летить уперед/назад — тримай скреб рівним, не штовхай убік."
      - "Не підстрибуєш — ноги заважають обертанню. Підбирай їх вище."
      - "Намагаєшся ловити дошку очима — лови ногами, дивись по центру."
    tip: "спершу можна вчити звичайний shuvit без попу (дошка не злітає), а вже потім додати поп."
    video: "https://www.youtube.com/results?search_query=how+to+pop+shuvit+beginner+tutorial"
    reps: "1–2 тижні"
  - id: 10
    label: "Олі + обертання тіла"
    title: "Frontside / Backside 180"
    goal: "зробити олі й розвернути себе разом із дошкою на 180°."
    svg: |
      <svg class="diagram" viewBox="0 0 320 150" role="img" aria-label="Олі з розворотом тіла на 180 градусів — goofy">
        <rect width="320" height="150" fill="#fff"/>
        <g transform="translate(90,55)">
          <path d="M0,28 q0,-26 26,-26 h88 q26,0 26,26 q0,26 -26,26 h-88 q-26,0 -26,-26 z" fill="#DCD7CB" stroke="#17150F" stroke-width="3"/>
          <rect x="14" y="-12" width="34" height="30" rx="8" fill="#FF4A1C" stroke="#17150F" stroke-width="2.5"/>
          <rect x="92" y="-12" width="32" height="30" rx="8" fill="#17150F"/>
        </g>
        <path d="M260,30 q-100,-30 -200,0" fill="none" stroke="#FF4A1C" stroke-width="3" marker-end="url(#arE)"/>
        <text x="80" y="20" fill="#FF4A1C" font-family="JetBrains Mono" font-size="11" font-weight="700">ПЛЕЧІ ВЕДУТЬ ОБЕРТ</text>
        <text x="70" y="135" fill="#17150F" font-family="JetBrains Mono" font-size="10" font-weight="700">FRONTSIDE = ОБЛИЧЧЯМ УПЕРЕД · BACKSIDE = СПИНОЮ</text>
      </svg>
    how:
      - "Перед попом <b>закрути плечі</b> в бік майбутнього обертання — це твій «завод пружини»."
      - "Роби олі й одночасно розкручуй плечі та стегна, дошка йде слідом за тілом."
      - "Голова веде обертання — повертай погляд туди, куди розвертаєшся."
      - "Доверни до 180°, приземляйся в <b>fakie/switch</b> стійці над болтами."
    mistakes:
      - "Крутиш тільки ноги без плечей — оберт не доходить. Заводь корпус заздалегідь."
      - "Недокрут до 90° — додай замаху плечима й трохи вищий олі."
      - "Дивишся під ноги — голова має вести розворот."
    tip: "backside 180 часто заходить легше — почни з того боку, що природніший саме тобі."
    video: "https://www.youtube.com/results?search_query=how+to+frontside+backside+180+ollie+beginner"
    reps: "2–3 тижні"
---
<div class="wrap">

  <!-- HERO -->
  <header>
    <div class="stripe"></div>
    <span class="kicker">Roadmap · Beginner → Trick</span>
    <h1>Скейт<br><span class="o">план</span></h1>
    <p class="lede">Покрокова прокачка від першого поштовху до перших трюків. Усе підлаштовано під <b>твою дошку та твою ногу</b> — не поспішай між кроками, кожен будує наступний.</p>

    <!-- SETUP CARD -->
    <div class="setup">
      <div class="sub">// твій сетап</div>
      <h2>Стандарт popsicle · під street + all-round</h2>
      <div class="spec-grid">
        <div class="spec"><div class="l">Ширина деки</div><div class="v">8.25"</div><div class="n">Золота середина: достатньо стабільно під трюки й комфортно під ногу 43-го.</div></div>
        <div class="spec"><div class="l">Конкейв</div><div class="v">Mid</div><div class="n">Універсальний прогин — гарний контроль ногами без надто різкого «замка».</div></div>
        <div class="spec"><div class="l">Розмір ноги</div><div class="v">EU 43</div><div class="n">≈ US 9.5–10, ступня ~27 см. Ідеально лягає на 8.25 — нога не звисає й не теліпається.</div></div>
        <div class="spec"><div class="l">Висновок</div><div class="v">Беремо!</div><div class="n">Цей сетап нічого не обмежує до рівня базових трюків. Міняти нічого не треба.</div></div>
      </div>

      <!-- DECK + CONCAVE SVG -->
      <svg class="setup-svg" viewBox="0 0 520 200" role="img" aria-label="Схема деки та профілю конкейву">
        <!-- top-view popsicle -->
        <g transform="translate(30,40)">
          <path d="M0,40 q0,-38 40,-38 h180 q40,0 40,38 q0,38 -40,38 h-180 q-40,0 -40,-38 z" fill="#211e15" stroke="#F4C20D" stroke-width="3"/>
          <!-- bolts -->
          <g fill="#FF4A1C"><circle cx="40" cy="22" r="4"/><circle cx="60" cy="22" r="4"/><circle cx="40" cy="58" r="4"/><circle cx="60" cy="58" r="4"/><circle cx="200" cy="22" r="4"/><circle cx="220" cy="22" r="4"/><circle cx="200" cy="58" r="4"/><circle cx="220" cy="58" r="4"/></g>
          <!-- width marker -->
          <line x1="270" y1="2" x2="270" y2="78" stroke="#b9b3a3" stroke-width="1.5"/>
          <text x="285" y="44" fill="#F4C20D" font-family="JetBrains Mono" font-size="13" font-weight="700">8.25"</text>
          <text x="10" y="98" fill="#b9b3a3" font-family="JetBrains Mono" font-size="11">ВИД ЗВЕРХУ · POPSICLE</text>
          <text x="20" y="-12" fill="#b9b3a3" font-family="JetBrains Mono" font-size="10">NOSE</text>
          <text x="190" y="-12" fill="#b9b3a3" font-family="JetBrains Mono" font-size="10">TAIL</text>
        </g>
        <!-- concave cross section -->
        <g transform="translate(330,40)">
          <path d="M0,10 C20,10 30,52 75,52 C120,52 130,10 150,10" fill="none" stroke="#F4C20D" stroke-width="3"/>
          <line x1="0" y1="10" x2="0" y2="70" stroke="#46412f" stroke-width="1.5"/>
          <line x1="150" y1="10" x2="150" y2="70" stroke="#46412f" stroke-width="1.5"/>
          <path d="M30,68 C30,55 120,55 120,68" fill="none" stroke="#FF4A1C" stroke-width="1.5" stroke-dasharray="3 3"/>
          <text x="38" y="84" fill="#FF4A1C" font-family="JetBrains Mono" font-size="11">MID</text>
          <text x="0" y="104" fill="#b9b3a3" font-family="JetBrains Mono" font-size="11">ПРОФІЛЬ · КОНКЕЙВ</text>
        </g>
      </svg>
      <div class="setup-note"><b style="color:var(--hazard)">Стійка: GOOFY.</b> Попереду в тебе <b style="color:var(--accent)">права нога</b> — отже вона завжди стоїть над передніми болтами. Штовхаєшся, гальмуєш і робиш поп <b style="color:var(--accent)">лівою (задньою)</b> ногою. Усі схеми нижче перемальовано саме під тебе: ніс дошки дивиться вліво — так твій рух виглядає збоку, коли права попереду.</div>
    </div>
  </header>

  <!-- PROGRESS -->
  <div class="progress-bar"><div class="progress-top"><span class="t">Твій прогрес</span><span class="c"><b id="pc-done">0</b>/<span id="pc-total">10</span> кроків</span></div><div class="bar"><span id="pc-fill"></span></div><button class="reset" id="resetBtn">скинути прогрес</button></div>

  {% for step in steps %}
  {% if step.phaseLabel %}
  <div class="phase"><div class="num">{{ step.phaseNum }}</div><div class="meta"><div class="lbl">Фаза</div><div class="nm">{{ step.phaseLabel }}</div></div></div>
  {% endif %}
  <article class="step" data-id="{{ step.id }}"><div class="step-head"><div class="badge">{{ step.id }}</div><div class="step-titles"><div class="st-l">{{ step.label }}</div><h3>{{ step.title }}</h3></div><div class="chk">✓</div></div><div class="step-body"><div class="goal"><b>Мета:</b> {{ step.goal }}</div>{{ step.svg | safe }}<ol class="how">{% for item in step.how %}<li>{{ item | safe }}</li>{% endfor %}</ol><div class="mistakes"><div class="mh"><span>⚠</span>Типові помилки</div><ul>{% for item in step.mistakes %}<li>{{ item | safe }}</li>{% endfor %}</ul></div><div class="tip"><b>Фішка:</b> {{ step.tip | safe }}</div><div class="step-foot"><a class="vid" target="_blank" rel="noopener" href="{{ step.video }}">▶ Відеоурок</a><span class="reps">⏱ {{ step.reps }}</span></div></div></article>
  {% endfor %}

  <!-- WHAT'S NEXT -->
  <footer>
    <h4>Що далі?</h4>
    <p style="font-size:.95rem">Коли ці 10 кроків стануть впевненими — у тебе є фундамент під <b>кікфліп</b>, <b>хілфліп</b>, мануали в комбо й перші перешкоди (бордюри, мануал-пед). Усе це будується на чистому олі, тож головне — не перестрибувати кроки.</p>

    <h4 style="margin-top:22px">Рекомендовані канали</h4>
    <div class="chan">
      <a target="_blank" rel="noopener" href="https://www.youtube.com/results?search_query=Braille+Skateboarding+how+to">Braille Skateboarding</a>
      <a target="_blank" rel="noopener" href="https://www.youtube.com/results?search_query=Skateboarding+Made+Simple+tutorial">Skateboarding Made Simple</a>
      <a target="_blank" rel="noopener" href="https://www.youtube.com/results?search_query=how+to+skateboard+українською+уроки">Уроки українською</a>
    </div>
    <p class="fnote">⚠ Усе вчи в шоломі та захисті, особливо олі й обертання. Падіння — частина процесу: вчись групуватись і котитись, а не виставляти прямі руки. Кнопки «Відеоурок» відкривають підбірку актуальних роликів на YouTube за темою кроку.</p>
    <div class="legend">// progress зберігається у цьому віджеті</div>
  </footer>

</div>
